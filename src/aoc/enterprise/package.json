{
  "name": "@aoc-enterprise/runtime",
  "version": "0.1.0",
  "description": "AOC enterprise runtime — delegation, policy evaluation, and execution grants for governance-aware workspaces",
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/enterprise/runtime/index.d.ts",
      "import": "./dist/enterprise/runtime/index.js"
    },
    "./runtime": {
      "types": "./dist/enterprise/runtime/index.d.ts",
      "import": "./dist/enterprise/runtime/index.js"
    },
    "./runtime/*": {
      "types": "./dist/enterprise/runtime/*.d.ts",
      "import": "./dist/enterprise/runtime/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Architects-of-Change-Protocol/pmfreak.git",
    "directory": "src/aoc/enterprise"
  },
  "main": "./dist/enterprise/runtime/index.js",
  "module": "./dist/enterprise/runtime/index.js",
  "types": "./dist/enterprise/runtime/index.d.ts",
  "sideEffects": false,
  "peerDependencies": {},
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json"
  }
}
